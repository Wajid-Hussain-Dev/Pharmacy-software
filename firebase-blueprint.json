{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "cashier", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Medicine inventory item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "genericName": { "type": "string" },
        "category": { "type": "string" },
        "batchNumber": { "type": "string" },
        "supplierId": { "type": "string" },
        "purchasePrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "quantity": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "lowStockThreshold": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "batchNumber", "sellingPrice", "quantity", "expiryDate"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Medicine supplier information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contact": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales transaction record",
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "medicineId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "discount": { "type": "number" },
        "tax": { "type": "number" },
        "finalAmount": { "type": "number" },
        "cashierId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "totalAmount", "finalAmount", "cashierId", "timestamp"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Inventory purchase record",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "medicineId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierId", "items", "totalAmount", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/medicines/{medicineId}": {
      "schema": "Medicine",
      "description": "Medicine inventory"
    },
    "/suppliers/{supplierId}": {
      "schema": "Supplier",
      "description": "Supplier records"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales transactions"
    },
    "/purchases/{purchaseId}": {
      "schema": "Purchase",
      "description": "Purchase records"
    }
  }
}
